DATABASE_URL="postgresql://postgres:postgres@localhost:5432/specagent_lab?schema=public"

# AI provider selection. When omitted, the app prefers SiliconFlow if SILICONFLOW_API_KEY is set; otherwise OpenAI.
AI_PROVIDER="siliconflow"

# Required for live agents (playground, benchmark) and optional LLM-as-judge evaluation when using OpenAI.
OPENAI_API_KEY=""

# Required for live agents (playground, benchmark) and optional LLM-as-judge evaluation when using SiliconFlow.
SILICONFLOW_API_KEY=""
SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"

# Public site URL for absolute links / metadata (local: http://localhost:3000).
# On Vercel you can omit this if you rely on VERCEL_URL; setting this explicitly is recommended for production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
